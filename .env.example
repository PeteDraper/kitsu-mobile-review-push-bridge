# ── Kitsu server ──────────────────────────────────────────────────────────────
# Full URL to your Kitsu instance — no trailing slash, no /api suffix
KITSU_URL=http://kitsu.studio.local

# Service account credentials — use a dedicated admin account, not a person's login
KITSU_EMAIL=push-bridge@studio.local
KITSU_PASSWORD=changeme

# ── Push relay ────────────────────────────────────────────────────────────────
# These values are the same for every installation.
# Copy them from the Kitsu Mobile Review setup documentation.
RELAY_URL=https://YOUR_RELAY_DOMAIN/api/notify
RELAY_SECRET=YOUR_RELAY_SECRET

# Use APNs sandbox endpoint?
# true  → development builds, TestFlight
# false → App Store / production builds
APNS_SANDBOX=true

# ── Bridge HTTP API ───────────────────────────────────────────────────────────
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=9090

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=./bridge_tokens.db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
