# ── Kitsu server ──────────────────────────────────────────────────────────────
# Full URL to your Kitsu instance — no trailing slash, no /api suffix
KITSU_URL=http://kitsu.studio.local

# Service account — use a dedicated admin account, not a personal login
KITSU_EMAIL=push-bridge@studio.local
KITSU_PASSWORD=changeme

# ── APNs environment ──────────────────────────────────────────────────────────
# false = App Store (default)
# true  = TestFlight internal builds only
APNS_SANDBOX=false

# ── Bridge HTTP API ───────────────────────────────────────────────────────────
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=9090

# ── Storage / logging ─────────────────────────────────────────────────────────
DB_PATH=./bridge_tokens.db
LOG_LEVEL=INFO
