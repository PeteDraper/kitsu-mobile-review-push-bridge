# ── Kitsu server ──────────────────────────────────────────────────────────────
# Full URL to your Kitsu instance — no trailing slash, no /api suffix
KITSU_URL=http://kitsu.studio.local

# Service account credentials — use a dedicated admin account, not a person's login
KITSU_EMAIL=push-bridge@studio.local
KITSU_PASSWORD=changeme

# ── Apple Push Notification service (APNs) ────────────────────────────────────
# Path to the .p8 auth key downloaded from developer.apple.com
# (Keys → + button → Apple Push Notifications service key)
APNS_KEY_PATH=/etc/kitsu-push-bridge/AuthKey_XXXXXXXXXX.p8

# 10-character Key ID shown next to the key on developer.apple.com
APNS_KEY_ID=XXXXXXXXXX

# 10-character Team ID — top-right of developer.apple.com when signed in
APNS_TEAM_ID=XXXXXXXXXX

# Bundle ID of the iOS app (must match app.json / Xcode project)
APNS_BUNDLE_ID=com.yourstudio.kitsu-client

# Use APNs sandbox endpoint?
# true  → development builds, TestFlight (Expo dev client, internal TestFlight)
# false → App Store / production builds
APNS_SANDBOX=false

# ── Bridge HTTP API ───────────────────────────────────────────────────────────
# Bind address — use 127.0.0.1 when proxied through Nginx (recommended)
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=9090

# Optional shared secret — if set, the app must include this in X-Bridge-Secret
BRIDGE_SECRET=

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=./bridge_tokens.db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
